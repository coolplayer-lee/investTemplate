{
  "framework": "vitepress",
  "buildCommand": "npm run docs:build",
  "outputDirectory": ".vitepress/dist",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/((?!assets/|favicon\\.ico|favicon\\.svg|favicon\\.png|logo\\.svg|dashboard/|vix_strategy/).*)",
      "destination": "/$1.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
